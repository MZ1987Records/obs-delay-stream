      "Read",
      "Glob",
      "Grep",
      "WebFetch(domain:*)",
      "WebSearch",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(ls *)",
      "Bash(cd *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(where *)",
      "Bash(test *)",
      "Bash(echo *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(pwd)",
      "Bash(npm run *)",
      "Bash(npx vite *)",
      "Bash(npx esbuild *)",
      "Bash(npx tsc *)",
      "Bash(./node_modules/.bin/vite build *)",
